# ApexVision AI — Backend Environment Configuration
# Copy to .env and fill in your values

# IBM Watsonx.ai — REQUIRED for real IBM Granite AI
IBM_WATSONX_URL=https://us-south.ml.cloud.ibm.com
IBM_WATSONX_API_KEY=your_ibm_watsonx_api_key_here
IBM_PROJECT_ID=your_ibm_project_id_here
IBM_GRANITE_MODEL=ibm/granite-13b-instruct-v2
IBM_GRANITE_VISION_MODEL=ibm/granite-20b-multimodal

# Database (match docker-compose.yml settings)
DATABASE_URL=postgresql://apexvision:apexvision@localhost:5432/apexvision
REDIS_URL=redis://localhost:6379

# App Security
DEBUG=false
SECRET_KEY=change_this_to_a_secure_random_string

# Computer Vision
YOLO_MODEL_PATH=models/yolov8n.pt
YOLO_CONFIDENCE=0.5
TRACKER_TYPE=bytetrack

# File Storage
UPLOAD_DIR=./uploads
OUTPUT_DIR=./outputs
MAX_VIDEO_SIZE_MB=500

# Docling / ChromaDB
CHROMADB_PATH=./data/chromadb
DOCLING_OUTPUT_DIR=./data/docling_parsed

# LangFlow Integration
LANGFLOW_URL=http://localhost:7860
