# ApexVision AI — Root Environment (Docker Compose)
# Copy to .env and fill in your values

# IBM Watsonx.ai (REQUIRED for real IBM Granite AI inference)
IBM_WATSONX_URL=https://us-south.ml.cloud.ibm.com
IBM_WATSONX_API_KEY=your_ibm_watsonx_api_key_here
IBM_PROJECT_ID=your_ibm_project_id_here
IBM_GRANITE_MODEL=ibm/granite-13b-instruct-v2

# Database passwords (change in production)
DB_PASSWORD=apexvision_secret
SECRET_KEY=change_this_to_a_secure_random_string_min_32_chars

# Public URLs (update for your deployment hostname)
PUBLIC_API_URL=http://localhost:8000
PUBLIC_WS_URL=ws://localhost:8000

# LangFlow
LANGFLOW_SECRET=apexvision-langflow-secret

# Debug mode (false in production)
DEBUG=false
